# Copia este archivo como .streamlit/secrets.toml y completa tus credenciales.
# Nunca subas .streamlit/secrets.toml a GitHub.

[mongodb]
uri = "mongodb+srv://USUARIO:CLAVE@cluster.mongodb.net/?retryWrites=true&w=majority"
database = "falabella_ecommerce"
collection = "productos"

[supabase]
url = "https://TU-PROYECTO.supabase.co"
# Para V1 usa anon/public/publishable key con politicas RLS.
# Evita usar service_role o secret key en apps publicas.
key = "TU_SUPABASE_ANON_O_PUBLISHABLE_KEY"
